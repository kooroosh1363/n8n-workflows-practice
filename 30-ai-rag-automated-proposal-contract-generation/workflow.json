    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO proposal_decisions (rfp_id, client_name, decision, decided_at) VALUES ('{{ $json.rfp_id }}', '{{ $json.client_name }}', '{{ $json.query.decision }}', NOW());",
        "options": {}
      },
